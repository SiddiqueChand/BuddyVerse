<section id="prof">
    <div class="pagetitle">
      <% if (Object.keys(errmessages).length > 0) { %>
        <div class="errmessages">
          <% Object.keys(errmessages).forEach(function (type) { %>
            <% errmessages[type].forEach(function (errmessage) { %>
              <div class="alert alert-<%= type %>">
                <%= errmessage %>
              </div>
            <% }) %>
          <% }) %>
        </div>
      <% } %>
    </div>
    <section class="section profile">
      <div class="row">
        <div class="col-xl-12">
          <div class="card">
            <div class="card-body profile-card pt-4 d-flex flex-column align-items-center">
              <i class="bi bi-person-circle" style="font-size: xx-large;"></i>
              <h2><%= BudName %></h2>
              <h3>Bud</h3>
            </div>
          </div>
    
          <div class="card mt-3">
            <div class="card-body pt-3">
              <!-- Bordered Tabs -->
              <ul class="nav nav-tabs nav-tabs-bordered">
                <li class="nav-item">
                  <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#profile-overview">Overview</button>
                </li>
                <li class="nav-item">
                  <button class="nav-link" data-bs-toggle="tab" data-bs-target="#assigned-buddy">Assigned Buddy</button>
                </li>
              </ul>
    
              <div class="tab-content pt-2">
                <!-- Overview Tab -->
                <div class="tab-pane fade show active" id="profile-overview">
                  <h5 class="card-title" style="color: #9c226f;"><b>Profile Details</b></h5>
                  <div class="row">
                    <div class="col-lg-3 col-md-4 label" style="color: #9c226f;">Name</div>
                    <div class="col-lg-9 col-md-8"><%= BudName %></div>
                  </div>
                  <br>
                  <div class="row">
                    <div class="col-lg-3 col-md-4 label" style="color: #9c226f;">Phone</div>
                    <div class="col-lg-9 col-md-8"><%= BudContactNumber %></div>
                  </div>
                  <br>
                  <div class="row">
                    <div class="col-lg-3 col-md-4 label" style="color: #9c226f;">Email</div>
                    <div class="col-lg-9 col-md-8"><%= BudEmail %></div>
                  </div>
                  <br>
                  <div class="row">
                    <div class="col-lg-3 col-md-4 label" style="color: #9c226f;">Stream</div>
                    <div class="col-lg-9 col-md-8"><%= BudStream %></div>
                  </div>
                </div>
    
                <!-- Assigned Buddy Tab -->
                <div class="tab-pane fade" id="assigned-buddy">
                  <h5 class="card-title" style="color: #9c226f;"><b>Assigned Buddy</b></h5>
                  <% if (AssignedBuddy) { %>
                    <div class="row">
                      <div class="col-lg-3 col-md-4 label" style="color: #9c226f;">Buddy ID</div>
                      <div class="col-lg-9 col-md-8"><%= AssignedBuddy.BuddyID %></div>
                    </div>
                    <br>
                    <div class="row">
                      <div class="col-lg-3 col-md-4 label" style="color: #9c226f;">Name</div>
                      <div class="col-lg-9 col-md-8"><%= AssignedBuddy.BuddyName %></div>
                    </div>
                  <% } else { %>
                    <p>No assigned Buddy</p>
                  <% } %>
                </div>
              </div>
              <!-- End Bordered Tabs -->
            </div>
          </div>
        </div>
      </div>
    </section>
    
  </main>
  <br>
  <br><a href="/logout-Bud" class="button button-accent">Log Out</a>
  <br>  <br>  <br>  <br>  <br>
</section>
    
