    <style>
      body {
          text-align: center;
          font-family: Arial, sans-serif;
          margin-top: 100px;
          position: relative;
      }

      .container {
          position: relative;
          display: inline-block;
      }

      .medicare {
          font-size: 125px;
          font-weight: bold;
          color: rgba(102, 102, 255, 0.3); /* Light purple faded effect */
          text-transform: uppercase;
          position: absolute;
          top: 0;
          left: 50%;
          transform: translateX(-50%);
          white-space: nowrap;
      }

      .best-medical {
          font-size: 90px;
          font-weight: bold;
          font-style: italic;
          color: black;
          text-transform: uppercase;
          position: relative;
          margin-top: 80px;
      }

      .treatment-center {
          font-size: 90px;
          font-weight: bold;
          color: #6666ff; /* Bold purple */
          text-transform: uppercase;
          position: relative;
      }

      .prof {
        display: flex;
        justify-content: center; /* Center horizontally */
        align-items: center; /* Center vertically */
        height: 100vh; /* Full viewport height */
