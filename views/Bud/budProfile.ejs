        list-style: none;
        margin: 0;
        padding: 0;
      }
      .nav-links a {
        text-decoration: none;
        color: #333;
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.9rem;
        transition: color 0.3s ease;
      }
      .nav-links b:hover {
        color: #ff00bf;
      }
    </style>
        <nav class="navigationbar">
