    <script>
      // Grab the container
      const scrollContainer = document.getElementById('scrollContainer');
  
      // Configuration for auto-scroll
      let scrollAmount = 0;
      const scrollStep = 1;     // How many pixels to move per tick
      const scrollDelay = 15;   // Milliseconds between scroll ticks
  
      function autoScroll() {
        // Move the scroll position to the right
        scrollAmount += scrollStep;
        scrollContainer.scrollLeft = scrollAmount;
  
        // If we've reached the end, reset to start
        if (scrollAmount >= (scrollContainer.scrollWidth - scrollContainer.clientWidth)) {
          scrollAmount = 0;
        }
      }
  
      // Start auto-scrolling
      setInterval(autoScroll, scrollDelay);
    </script>
