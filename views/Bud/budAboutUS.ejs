  <!-- CSS -->
  <style>
      /* Footer Base Styles */
      .footer {
          background-image: url('/images/footer.jpg');
          background-size: cover;
          background-position: center;
          color: white;
          padding: 40px 20px;
          font-family: 'Poppins', sans-serif;
          text-align: center;
      }
  
      /* Footer Container */
      .footer-container {
          display: flex;
          justify-content: space-between;
          align-items: center;
          flex-wrap: wrap;
          max-width: 1100px;
          margin: 0 auto;
      }
  
      /* Branding */
      .footer-branding {
          display: flex;
          align-items: center;
          text-align: left;
          margin-left: 1px ;
      }
  
      .footer-branding img {
          height: 100px;
          margin-right: 15px;
      }
  
      .footer-branding h4 {
          color: #8a75ff;
          margin: 0;
      }
  
      .footer-branding p {
          text-transform: uppercase;
          font-size: 12px;
          opacity: 0.8;
          margin: 0;
      }
  
      /* Contact Section */
      .footer-contact {
          text-align: right;
      }
  
      .footer-contact h5 {
          color: #8a75ff;
          font-weight: bold;
          margin-bottom: 10px;
      }
  
      .footer-contact p {
          margin: 5px 0;
      }
  
      .footer-contact a {
          color: white;
          text-decoration: none;
          transition: color 0.3s ease-in-out;
      }
  
      .footer-contact a:hover {
          color: #8a75ff;
      }
  
      /* Separator Line */
      .footer-line {
          border: none;
          height: 2px;
          background-color: rgba(255, 255, 255, 0.3);
          width: 100%;
          margin: 30px 0;
      }
  
      /* Social Media Icons */
      .footer-bottom {
          text-align: center;
      }
  
      .social-icons {
          margin-bottom: 15px;
      }
  
      .social-icons a {
          display: inline-block;
          margin: 0 10px;
          font-size: 18px;
          color: white;
          transition: 0.3s;
      }
  
      .social-icons a:hover {
          color: #8a75ff;
          transform: scale(1.1);
      }
  
      .footer-bottom p {
          font-size: 14px;
          opacity: 0.8;
      }
  
      .footer-bottom span {
          color: #8a75ff;
          font-weight: bold;
      }
    </style>
  

