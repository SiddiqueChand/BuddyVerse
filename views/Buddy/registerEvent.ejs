  <script>
    const form = document.getElementById("eventRegForm");
  
    form.addEventListener("submit", async function (e) {
      e.preventDefault(); // prevent page reload
  
      const formData = new FormData(form);
      const data = {};
      formData.forEach((value, key) => {
        data[key] = value;
      });
  
      try {
        const response = await fetch("/submitregi-Buddy", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify(data)
        });
      
        if (response.ok) {
          document.getElementById("successPopup").style.display = "block";
          form.reset();
          // Clear any previous error messages
          document.getElementById("errmessages").innerHTML = "";
        } else {
          // Expecting the server to return a JSON object with an "errmessages" property
          const result = await response.json();
          let errHtml = "";
          if (result.errmessages) {
            Object.keys(result.errmessages).forEach(type => {
              result.errmessages[type].forEach(message => {
                errHtml += `<div class="alert alert-${type}">${message}</div>`;
              });
            });
          } else {
            errHtml = `<div class="alert alert-danger">Registration failed. Try again.</div>`;
          }
          document.getElementById("errmessages").innerHTML = errHtml;
        }
      } catch (error) {
        console.error("Error:", error.message);
        document.getElementById("errmessages").innerHTML = `<div class="alert alert-danger">${error.message}</div>`;
      }
    });
  
    function closePopup() {
      document.getElementById("successPopup").style.display = "none";
    }
  </script>
  
  
    

    <script>
        // Function to get URL query parameters
        function getQueryParam(param) {
            const urlParams = new URLSearchParams(window.location.search);
            return urlParams.get(param);
        }

        // On page load, capture event details (if any) and add them to the hidden input fields
        window.onload = function () {
            const event = getQueryParam('event');
            const startDate = getQueryParam('startDate');
            const endDate = getQueryParam('endDate');
            const type = getQueryParam('type');
            const location = getQueryParam('location');
            const about = getQueryParam('about');

            // Set the values of the hidden inputs with the event and date information
            if (event && startDate && endDate && type && location && about) {
                document.getElementById('event').value = event;
                document.getElementById('startDate').value = startDate;
                document.getElementById('endDate').value = endDate;
                document.getElementById('type').value = type;
                document.getElementById('location').value = location;
                document.getElementById('about').value = about;
            }
        }
    </script>
